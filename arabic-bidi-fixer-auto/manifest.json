{
  "manifest_version": 3,
  "name": "Arabic BiDi Fixer (Auto)",
  "version": "1.1",
  "description": "يُصلح تشوه النص العربي تلقائيًا. مع صفحة إعدادات للقائمة السوداء.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
